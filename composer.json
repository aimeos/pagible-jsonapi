{
    "name": "aimeos/pagible-jsonapi",
    "description": "Pagible CMS - JSON:API server",
    "keywords": ["laravel", "cms", "jsonapi"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "LGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-core": "0.10.*",
        "laravel-json-api/laravel": "^5.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\JsonapiServiceProvider"
            ]
        }
    }
}
